# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# STRIPE_SECRET_KEY: Required for Stripe balance and payment APIs.
# Get your Stripe Secret Key from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder

# STRIPE_PUBLISHABLE_KEY: Required for Stripe Checkout or client operations.
# Get your Stripe Publishable Key from dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
